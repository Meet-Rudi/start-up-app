{
  "schema_version": "1.0",
  "description": "Canonical field registry for the Meet Rudi / CM pilot consent+intake form. Keys are English and language-neutral; the id column matches the element ids in both the EN and NL form so values can be extracted identically regardless of the language the respondent saw. Values are STORED in the submitted language (NL for the live form) with these EN keys, so no information is lost in translation.",
  "fields": [
    {"key": "first_name", "id": "voornaam", "type": "string", "required": true,
     "max_len": 120, "used_in_filename": true},
    {"key": "mobile_number", "id": "gsm", "type": "phone", "required": true,
     "normalize": "e164", "default_country": "+32",
     "note": "WhatsApp identifier; accepts +32 4XX XX XX XX or 04XX XX XX XX"},
    {"key": "whatsapp_number_confirmed", "id": "gsmConfirm", "type": "bool", "required": true,
     "must_be_true": true,
     "note": "Attestation that the number is already active on WhatsApp"},
    {"key": "email", "id": "email", "type": "email", "required": true, "max_len": 254},
    {"key": "year_of_birth", "id": "geboortejaar", "type": "int", "required": true,
     "min": 1930, "max": 2008},
    {"key": "gender", "id": "geslacht", "type": "enum", "required": true,
     "options": {"nl": ["vrouw", "man", "anders", "zeg ik liever niet"],
                 "en": ["female", "male", "other", "prefer not to say"]}},
    {"key": "municipality", "id": "gemeente", "type": "string", "required": true, "max_len": 120},
    {"key": "cm_member_t2d", "id": "cmLid", "type": "bool", "required": false,
     "special_category": true,
     "note": "Health data (Art. 9): CM member diagnosed with type 2 diabetes after 2016"},
    {"key": "help_areas", "id": "help", "type": "multi_enum", "required": true,
     "min_items": 1, "max_items": 2, "special_category": true,
     "options": {"nl": ["Gezonder eten", "Meer bewegen", "Beter slapen",
                          "Mijn motivatie volhouden", "Omgaan met stress", "Meer energie krijgen"],
                 "en": ["Eating healthier", "Moving more", "Sleeping better",
                          "Keeping up my motivation", "Dealing with stress", "Getting more energy"]}},
    {"key": "confidence_self_improve", "id": "q2", "type": "int", "required": true,
     "min": 0, "max": 10, "slider": true},
    {"key": "energy_past_week", "id": "q3", "type": "int", "required": true,
     "min": 0, "max": 10, "slider": true, "special_category": true},
    {"key": "healthy_living_past_week", "id": "q4", "type": "int", "required": true,
     "min": 0, "max": 10, "slider": true, "special_category": true},
    {"key": "support_felt", "id": "q5", "type": "int", "required": true,
     "min": 0, "max": 10, "slider": true},
    {"key": "active_days_past_week", "id": "q6", "type": "int", "required": true,
     "min": 0, "max": 7, "special_category": true},
    {"key": "prior_digital_tools", "id": "q7", "type": "enum", "required": true,
     "options": {"nl": ["Nee, dit is de eerste keer", "Ja, maar ik haakte af",
                          "Ja, en ik gebruik er nog steeds een"],
                 "en": ["No, this is the first time", "Yes, but I dropped out",
                          "Yes, and I still use one"]}},
    {"key": "notes_for_rudi", "id": "q8", "type": "string", "required": false, "max_len": 2000,
     "note": "Free text; may contain health information"}
  ],
  "consents": [
    {"key": "consent_health_data_processing", "id": "consent1", "required": true, "must_be_true": true,
     "special_category": true, "lawful_basis": "explicit_consent_art9",
     "note": "Explicit consent to process health data for coaching + anonymous pilot evaluation"},
    {"key": "consent_followup_contact", "id": "consent2", "required": false, "must_be_true": false,
     "lawful_basis": "consent", "note": "Optional consent to be contacted about a follow-up"}
  ],
  "captured_metadata": [
    "form_language", "form_version", "privacy_policy_version", "terms_version",
    "consent_text", "received_at", "ip_address", "user_agent"
  ]
}
